{
  "name": "socket.io-mp",
  "version": "0.3.0",
  "description": "socket.io client for WeChat, Alipay & Douyin (ByteDance) mini-programs — official socket.io-client with a native mini-program WebSocket transport",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chooin/socket.io-mp.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "socket.io",
    "socket.io-client",
    "websocket",
    "miniprogram",
    "weapp",
    "wechat",
    "alipay",
    "douyin",
    "bytedance",
    "tt",
    "taro",
    "uni-app"
  ],
  "author": "chooin <chooin@126.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "engine.io-client": "^6.6.6",
    "engine.io-parser": "^5.2.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@mini-types/alipay": "^3.0.14",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "miniprogram-api-typings": "^5.2.1",
    "socket.io": "^4.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  },
  "packageManager": "pnpm@11.9.0"
}
